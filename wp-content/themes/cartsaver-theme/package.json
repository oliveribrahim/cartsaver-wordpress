{
  "name": "cartsaver-theme",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind CSS build tooling for the cartsaver WordPress theme.",
  "scripts": {
    "dev": "tailwindcss -i ./src/css/app.css -o ./style.css --watch --postcss",
    "build": "NODE_ENV=production tailwindcss -i ./src/css/app.css -o ./style.css --minify --postcss"
  },
  "keywords": [
    "wordpress",
    "theme",
    "tailwindcss"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  }
}

